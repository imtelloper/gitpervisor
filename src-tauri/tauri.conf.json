{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gitpervisor",
  "version": "0.1.0",
  "identifier": "com.greathoon.gitpervisor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "imtelloper <newtype9556@gmail.com>",
    "copyright": "Copyright © 2026 imtelloper",
    "category": "DeveloperTool",
    "shortDescription": "멀티 레포 Git 대시보드",
    "longDescription": "여러 로컬 프로젝트의 git 상태를 한 화면에서 감시하고, diff 확인부터 커밋·푸시까지 처리하는 멀티 레포 Git 대시보드 데스크톱 앱입니다. (Tauri 2 + React 19)",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

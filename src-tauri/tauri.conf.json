{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gitpervisor",
  "version": "0.3.1",
  "identifier": "com.greathoon.gitpervisor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:39090",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self' http://localhost:* http://127.0.0.1:*; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBMjI1OEU5NjBEMDAyMEUKUldRT0F0Qmc2VmdpZXZaU1ZvamNjU0RhMVIzbFZqYmZiQml5Yll5a0dKTTRoQVQyMWk0bHN6SjUK",
      "endpoints": [
        "https://github.com/imtelloper/gitpervisor/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/tools/*": "tools"
    },
    "publisher": "imtelloper <newtype9556@gmail.com>",
    "copyright": "Copyright © 2026 imtelloper",
    "category": "DeveloperTool",
    "shortDescription": "멀티 레포 Git 대시보드",
    "longDescription": "여러 로컬 프로젝트의 git 상태를 한 화면에서 감시하고, diff 확인부터 커밋·푸시까지 처리하는 멀티 레포 Git 대시보드 데스크톱 앱입니다. (Tauri 2 + React 19)",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Korean"]
      }
    }
  }
}
